{
  "name": "stack-link",
  "version": "1.0.0-next.1",
  "description": "A navigation optimization library that delivers native-app-like, smooth page transitions in Next.js web applications",
  "license": "MIT",
  "packageManager": "yarn@4.9.3",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/geongyu09/stack-link.git"
  },
  "homepage": "https://github.com/geongyu09/stack-link",
  "keywords": [
    "nextjs",
    "react",
    "navigation",
    "page-transition",
    "prefetch",
    "link",
    "webview"
  ],
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup ./src/index.ts --watch",
    "build": "tsup ./src/index.ts",
    "start": "tsup",
    "test": "jest",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "yarn type-check && yarn test && yarn build"
  },
  "peerDependencies": {
    "next": "^15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/preset-env": "^7.28.0",
    "@babel/preset-react": "^7.27.0",
    "@babel/preset-typescript": "^7.27.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-jest": "^30.4.1",
    "eslint": "^9.0.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jiti": "^2.5.1",
    "next": "^15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.0.0"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  }
}
